API_BASE_URL=http://localhost:18090/api

# Recommended: set USERNAME/PASSWORD and let the tool log in.
USERNAME=admin
PASSWORD=

# Advanced use only: complete HTTP Authorization header, for example "Bearer eyJ...".
AUTHORIZATION_HEADER=

# Absolute path to the dataset directory that contains 0/ ... 20/ subdirectories.
DATA_DIR=/absolute/path/to/data

# These values must already exist in the project seed taxonomy.
CATEGORY_CODE=TEXTILE_DEFECT
CATEGORY_NAME=纺织瑕疵
TAG_GROUP_CODE=DEFECT
TAG_GROUP_NAME=瑕疵

# Keep true for preview mode. Set to false only when you are ready to upload.
DRY_RUN=true
BATCH_SIZE=50

# Local checkpoint and reporting. These files are local runtime artifacts.
RESUME=false
RETRY_FAILED=false
RUN_DIR=.import-runs
REPORT_FILE=
